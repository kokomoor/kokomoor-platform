# Kokomoor Platform — Environment Variables
# Copy to .env and fill in your values.
# Prefix: KP_ (parsed by Pydantic Settings)

# --- Environment ---
KP_ENVIRONMENT=dev

# --- LLM (Anthropic) ---
KP_ANTHROPIC_API_KEY=sk-ant-...
KP_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database ---
# Default: SQLite in ./data/platform.db
# For Postgres: KP_DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
# KP_DATABASE_URL=

# --- Observability ---
KP_LOG_LEVEL=INFO
KP_LOG_JSON=false
# KP_LANGSMITH_API_KEY=ls-...
# KP_LANGSMITH_PROJECT=kokomoor-platform

# --- Browser ---
KP_BROWSER_HEADLESS=true
KP_BROWSER_RATE_LIMIT_SECONDS=5.0
KP_ENABLE_BROWSER_STEALTH=true

# --- HTTP fetch (core.fetch) ---
# KP_FETCH_HTTP_TIMEOUT_SECONDS=20
# KP_FETCH_HTTP_MAX_RETRIES=2
# KP_FETCH_BROWSER_POST_WAIT_MS=1500
# KP_FETCH_BROWSER_TIMEOUT_MS=20000

# --- Resume Tailoring ---
# KP_RESUME_MASTER_PROFILE_PATH=pipelines/job_agent/context/candidate_profile.yaml
# KP_RESUME_OUTPUT_DIR=data/tailored_resumes
# KP_RESUME_ENABLE_CRITIQUE=false

# --- Job Analysis Node ---
# Model for structured JD extraction (separate node, runs before tailoring).
KP_JOB_ANALYSIS_MODEL=claude-haiku-4-5-20251001
KP_JOB_ANALYSIS_MAX_TOKENS=2048
# Safety cap on description chars sent to LLM (default 30000).
# KP_JOB_ANALYSIS_MAX_INPUT_CHARS=30000
KP_JOB_ANALYSIS_ENABLE_CACHE=true

# Plan pass model (empty = use KP_ANTHROPIC_MODEL, i.e. Sonnet).
# KP_RESUME_PLAN_MODEL=
KP_RESUME_PLAN_MAX_TOKENS=2048

# --- Cover Letter Tailoring ---
# KP_COVER_LETTER_MODEL=claude-sonnet-4-20250514
# KP_COVER_LETTER_MAX_TOKENS=2200
# KP_COVER_LETTER_MAX_INPUT_CHARS=12000
# KP_COVER_LETTER_STYLE_GUIDE_PATH=pipelines/job_agent/context/cover_letter_style.md
# KP_COVER_LETTER_OUTPUT_DIR=data/tailored_cover_letters
# KP_COVER_LETTER_TEMPLATE_PATH=
# KP_COVER_LETTER_ENABLE_CRITIQUE=false

# --- Discovery Node ---
# Browser session persistence (gitignored — sessions reused across runs)
# KP_DISCOVERY_SESSIONS_DIR=data/sessions
# KP_DISCOVERY_SESSION_MAX_AGE_HOURS=72

# Concurrency (each browser provider runs in its own Playwright context)
# KP_DISCOVERY_MAX_CONCURRENT_PROVIDERS=2
# KP_DISCOVERY_MAX_PAGES_PER_SEARCH=8
# KP_DISCOVERY_MAX_LISTINGS_PER_PROVIDER=150

# LinkedIn (requires account credentials — sessions persist so you rarely need to re-auth)
# KP_LINKEDIN_EMAIL=you@example.com
# KP_LINKEDIN_PASSWORD=your-password

# ATS providers — comma-separated slugs (no browser needed, uses public APIs)
# KP_GREENHOUSE_TARGET_COMPANIES=anduril,palantir,scale-ai,openai,anthropic
# KP_LEVER_TARGET_COMPANIES=openai,figma,notion

# CAPTCHA strategy: avoid | pause_notify | solve
# KP_CAPTCHA_STRATEGY=pause_notify
# KP_CAPTCHA_API_KEY=

# Pre-filter: 0.0 = accept all, 0.3 = require some keyword/role match
# KP_DISCOVERY_PREFILTER_MIN_SCORE=0.0

# Workday ATS (enterprise career sites — requires company config)
# Format: "CompanyName:subdomain[:wdN]" e.g. "Raytheon:rtx:wd1,Northrop:northrop:wd5"
# KP_WORKDAY_TARGET_COMPANIES=
# KP_DISCOVERY_WORKDAY_ENABLED=false

# Direct career site scraper (YAML config file path, optional)
# KP_DIRECT_SITE_CONFIGS=

# Provider toggles
# KP_DISCOVERY_LINKEDIN_ENABLED=true
# KP_DISCOVERY_INDEED_ENABLED=true
# KP_DISCOVERY_BUILTIN_ENABLED=true
# KP_DISCOVERY_WELLFOUND_ENABLED=false
# KP_DISCOVERY_GREENHOUSE_ENABLED=true
# KP_DISCOVERY_LEVER_ENABLED=true

# --- Notifications ---
# KP_SMTP_HOST=smtp.gmail.com
# KP_SMTP_PORT=587
# KP_SMTP_USERNAME=
# KP_SMTP_PASSWORD=
# KP_NOTIFICATION_FROM_EMAIL=
# KP_NOTIFICATION_TO_EMAIL=
